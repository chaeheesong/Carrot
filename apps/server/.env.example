# ── DB 비밀번호는 여기 한 곳에만 (원본 그대로, 특수문자 OK) ──
# 아래 URL의 __PW__ 자리에 코드가 URL-인코딩해서 자동으로 끼워넣습니다.
DB_PASSWORD="여기에_Supabase_DB_비밀번호_원본그대로"

# Supabase Postgres 연결 문자열 (env.md의 "1. Supabase" 참고)
# 비밀번호 자리는 반드시 __PW__ 로 그대로 두세요 (직접 넣지 마세요).
# 앱 런타임용 (Connection Pooling, 6543 포트)
DATABASE_URL="postgresql://postgres.tgipathnscdhybwzmqql:__PW__@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# 마이그레이션용 (Direct/session pooler, 5432 포트)
DIRECT_URL="postgresql://postgres.tgipathnscdhybwzmqql:__PW__@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres"

# 아무 랜덤 문자열 (예: openssl rand -base64 32)
JWT_SECRET="change-me-to-a-long-random-string"

# 서버 포트 (Render 등에서는 자동 주입)
PORT=4000

# 프론트 오리진(CORS 허용). 로컬은 http://localhost:3000
CORS_ORIGIN="http://localhost:3000"
